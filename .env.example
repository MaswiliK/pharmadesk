# Copy this file to .env and fill in all values before running the app.

# ── Flask ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
FLASK_DEBUG=false

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/pharma_db

# ── M-Pesa (Daraja portal: developer.safaricom.co.ke) ──────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_TILL_NUMBER=
MPESA_PASSKEY=
PUBLIC_BASE_URL=

# ── Seeded admin account (used by seed.py only) ────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_PHONE=
ADMIN_EMAIL=